@using System.Globalization
<!DOCTYPE html>
<html lang="@CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — VetAmb</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🐾</text></svg>" />
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        #mobile-nav-toggle {
            display: none;
            align-items: center;
            gap: 0.5rem;
            padding: 0.55rem 0.9rem;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            background: rgba(255, 255, 255, 0.08);
            color: var(--text-primary);
            font: inherit;
            font-size: 0.88rem;
            font-weight: 600;
            cursor: pointer;
            flex-shrink: 0;
        }

        #mobile-nav-backdrop {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(8, 10, 25, 0.55);
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
            z-index: 1400;
        }

        #mobile-nav-drawer {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: min(84vw, 320px);
            height: 100vh;
            padding: 1.5rem 1rem;
            background: rgba(15, 12, 41, 0.96);
            backdrop-filter: blur(18px);
            -webkit-backdrop-filter: blur(18px);
            border-right: 1px solid rgba(255, 255, 255, 0.12);
            transform: translateX(-100%);
            transition: transform 0.25s ease;
            z-index: 1500;
            overflow-y: auto;
        }

        body.mobile-nav-open #mobile-nav-backdrop {
            display: block;
        }

        body.mobile-nav-open #mobile-nav-drawer {
            display: block;
            transform: translateX(0);
        }

        #mobile-nav-drawer .drawer-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            margin-bottom: 1.5rem;
        }

        #mobile-nav-drawer .drawer-title {
            font-size: 1rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        #mobile-nav-close {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: 1px solid rgba(255, 255, 255, 0.16);
            background: rgba(255, 255, 255, 0.08);
            color: var(--text-primary);
            font-size: 1.1rem;
            cursor: pointer;
            flex-shrink: 0;
        }

        #mobile-nav-drawer .drawer-nav {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 0.4rem;
            padding: 0;
            margin: 0;
        }

        #mobile-nav-drawer .drawer-nav a {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.8rem 0.95rem;
            border-radius: 14px;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 0.92rem;
            font-weight: 500;
            transition: background 0.2s ease, color 0.2s ease;
        }

        #mobile-nav-drawer .drawer-nav a:hover,
        #mobile-nav-drawer .drawer-nav a.active {
            background: rgba(255, 255, 255, 0.1);
            color: var(--text-primary);
        }

        #global-search-container {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            flex-wrap: nowrap;
            width: 100%;
            max-width: 100%;
            margin-left: auto;
            margin-right: 0;
            padding: 0.35rem 0 !important;
            overflow: visible;
            row-gap: 0.45rem;
        }

        #global-search-row {
            display: flex;
            flex-direction: column-reverse;
            align-items: flex-end;
            flex-wrap: nowrap;
            gap: 0.45rem;
            width: auto;
            max-width: 100%;
            min-width: 0;
        }

        @@media (max-width: 1024px) {
            #mobile-nav-toggle {
                display: none;
            }

            #global-search-container {
                display: flex;
                flex-direction: row;
                align-items: flex-start;
                justify-content: flex-end;
                width: 100%;
                margin-right: 0;
                margin-left: 0;
                gap: 0.75rem;
            }

            #global-search-row {
                width: auto;
                gap: 0.45rem;
                margin-left: auto;
            }

            #global-search-wrapper {
                width: min(100%, 320px);
                max-width: 320px;
            }
        }

        #global-search-wrapper {
            position: relative;
            width: 220px;
            flex-shrink: 0;
            transition: width 0.2s ease;
        }

        @@media (min-width: 1200px) {
            #global-search-wrapper {
                width: 320px;
            }
        }

        @@media (max-width: 640px) {
            #mobile-nav-toggle {
                display: inline-flex;
                grid-area: toggle;
                align-self: start;
                margin-top: 0.1rem;
            }

            #global-search-container {
                display: grid;
                grid-template-columns: auto minmax(0, 1fr);
                grid-template-areas:
                    "toggle auth"
                    "search search";
                align-items: start;
                row-gap: 0.8rem;
            }

            #global-search-row {
                display: contents;
            }

            #global-search-wrapper {
                grid-area: search;
                width: 100%;
                max-width: 100%;
                margin-top: 0.1rem;
            }

            #auth-controls-slot {
                grid-area: auth;
                justify-self: end;
                justify-content: flex-end;
                margin-left: 0;
                width: auto;
                min-width: 0;
                max-width: 100%;
                overflow: hidden;
            }

            .auth-login-partial {
                flex-wrap: nowrap;
                justify-content: flex-end;
                gap: 0.4rem;
                max-width: 100%;
            }

            .auth-login-partial.auth-login-partial-signed-in {
                gap: 0.22rem;
            }

            .auth-glass-btn {
                padding: 0.28rem 0.6rem !important;
                font-size: 0.78rem !important;
            }

            .auth-username {
                max-width: clamp(72px, 30vw, 112px);
                font-size: 0.78rem;
            }
        }

        @@media (min-width: 641px) {
            #mobile-nav-toggle {
                display: none !important;
            }

            #mobile-nav-backdrop,
            #mobile-nav-drawer {
                display: none !important;
            }

            .app-shell {
                grid-template-columns: var(--sidebar-width) 1fr !important;
            }

            .sidebar {
                display: flex !important;
            }

            .main-content {
                grid-column: 2 !important;
            }
        }

        @@media (max-width: 400px) {
            .auth-login-partial {
                gap: 0.35rem;
            }

            .auth-username {
                max-width: clamp(64px, 26vw, 92px);
                font-size: 0.72rem;
            }

            .auth-glass-btn {
                padding: 0.25rem 0.5rem !important;
                font-size: 0.75rem !important;
                border-radius: 20px !important;
            }
        }

        #global-search-container .nav-link,
        #global-search-container .btn-link {
            white-space: nowrap;
        }

        #auth-controls-slot {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            flex-shrink: 0;
            min-width: 0;
        }

        .auth-login-partial {
            display: flex;
            min-width: 0;
            flex-wrap: nowrap;
            align-items: center;
            gap: 0.7rem;
        }

        .auth-login-partial.auth-login-partial-signed-in {
            flex-direction: column;
            align-items: flex-end;
            gap: 0.28rem;
        }

        .auth-login-partial.auth-login-partial-guest {
            flex-direction: row;
            align-items: center;
        }

        .auth-username {
            display: block;
            padding: 0;
            border-radius: 0;
            background: none;
            border: none;
            color: rgba(255, 255, 255, 0.96);
            font-weight: 600;
            font-size: 0.83rem;
            line-height: 1.1;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 220px;
            text-align: right;
        }

        #global-search-container .auth-login-partial form {
            margin: 0;
        }

        .auth-logout-form {
            display: flex;
            justify-content: flex-end;
            width: 100%;
            margin: 0;
        }

        #global-search-container .auth-glass-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 0.32rem 0.78rem;
            border-radius: 28px;
            background: rgba(255, 255, 255, 0.38);
            border: 1px solid rgba(255, 255, 255, 0.42);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            color: #111;
            font-weight: 600;
            font-size: 0.83rem;
            line-height: 1.1;
            text-decoration: none;
            font-family: inherit;
            cursor: pointer;
            appearance: none;
            -webkit-appearance: none;
            box-shadow: 0 8px 24px rgba(31, 38, 135, 0.10);
            transition: background 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
        }

        #global-search-container .auth-glass-btn:hover,
        #global-search-container .auth-glass-btn:focus {
            background: rgba(255, 255, 255, 0.56);
            box-shadow: 0 10px 26px rgba(31, 38, 135, 0.18);
            transform: translateY(-1px);
            color: #111;
            text-decoration: none;
        }

        #search-results-dropdown {
            border-radius: 20px;
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.25);
            box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.15);
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            z-index: 1060;
            margin-top: 8px;
            overflow: hidden;
            padding: 10px 0;
            display: none;
            max-height: 350px;
            overflow-y: auto;
        }

        #search-results-dropdown .dropdown-item {
            font-size: 0.92rem;
            line-height: 1.25rem;
            color: #111;
            transition: background 0.3s ease;
        }

        #search-results-dropdown .dropdown-item:last-child {
            border-bottom: none;
        }

        #search-results-dropdown .dropdown-item:hover,
        #search-results-dropdown .dropdown-item:focus {
            background: rgba(255, 255, 255, 0.4);
        }

        #global-search-input {
            width: 100%;
            background: rgba(255, 255, 255, 0.4);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.30);
            border-radius: 12px;
            color: #111;
            font-family: inherit;
            font-size: 0.92rem;
            padding: 10px 15px;
            outline: none;
            transition: border-color 0.2s cubic-bezier(0.4,0,0.2,1),
                        box-shadow 0.2s cubic-bezier(0.4,0,0.2,1);
            -webkit-appearance: none;
            appearance: none;
        }

        #global-search-input::placeholder {
            color: rgba(17, 17, 17, 0.55);
        }

        #global-search-input:focus {
            border-color: rgba(108,99,255,0.6);
            box-shadow: 0 0 0 3px rgba(108,99,255,0.15);
        }

        #ai-chat-toggle {
            position: fixed;
            right: 24px;
            bottom: 24px;
            width: 62px;
            height: 62px;
            border: none;
            border-radius: 50%;
            background: linear-gradient(135deg, #8b5cf6, #6d28d9);
            color: #f5f3ff;
            font-size: 1.5rem;
            cursor: pointer;
            z-index: 1700;
            box-shadow: 0 14px 32px rgba(109, 40, 217, 0.35);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        #ai-chat-toggle:hover {
            transform: translateY(-2px) scale(1.02);
            box-shadow: 0 18px 36px rgba(109, 40, 217, 0.42);
        }

        #ai-chat-widget {
            position: fixed;
            right: 24px;
            bottom: 96px;
            width: min(380px, calc(100vw - 20px));
            height: min(540px, calc(100vh - 130px));
            background: rgba(6, 22, 33, 0.92);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 22px;
            box-shadow: 0 24px 50px rgba(0, 0, 0, 0.28);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            display: none;
            flex-direction: column;
            overflow: hidden;
            z-index: 1700;
        }

        #ai-chat-widget.open {
            display: flex;
        }

        #ai-chat-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 0.75rem;
            padding: 0.95rem 1rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.12);
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.34), rgba(109, 40, 217, 0.16));
            color: #f5f3ff;
        }

        #ai-chat-header strong {
            font-size: 0.92rem;
            letter-spacing: 0.02em;
        }

        #ai-chat-header-actions {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
        }

        #ai-chat-clear,
        #ai-chat-close {
            width: 32px;
            height: 32px;
            border: none;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.16);
            color: #ecfdf5;
            font-size: 1.05rem;
            line-height: 1;
            cursor: pointer;
        }

        #ai-chat-clear {
            font-size: 0.92rem;
        }

        #ai-chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 1rem;
            display: flex;
            flex-direction: column;
            gap: 0.65rem;
            background: linear-gradient(180deg, rgba(7, 31, 46, 0.88), rgba(5, 21, 31, 0.95));
        }

        .ai-chat-row {
            display: flex;
        }

        .ai-chat-row.user {
            justify-content: flex-end;
        }

        .ai-chat-row.assistant {
            justify-content: flex-start;
        }

        .ai-chat-bubble {
            max-width: 84%;
            border-radius: 14px;
            padding: 0.6rem 0.75rem;
            white-space: pre-wrap;
            font-size: 0.87rem;
            line-height: 1.35;
            word-break: break-word;
        }

        .ai-chat-row.user .ai-chat-bubble {
            background: rgba(139, 92, 246, 0.9);
            color: #f5f3ff;
            border-bottom-right-radius: 4px;
        }

        .ai-chat-row.assistant .ai-chat-bubble {
            background: rgba(255, 255, 255, 0.14);
            color: #f1f5f9;
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-bottom-left-radius: 4px;
        }

        .ai-chat-typing {
            display: inline-flex;
            gap: 0.24rem;
            align-items: center;
            min-height: 1.1rem;
        }

        .ai-chat-typing span {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: rgba(241, 245, 249, 0.9);
            animation: ai-chat-pulse 0.9s infinite ease-in-out;
        }

        .ai-chat-typing span:nth-child(2) {
            animation-delay: 0.14s;
        }

        .ai-chat-typing span:nth-child(3) {
            animation-delay: 0.28s;
        }

        @@keyframes ai-chat-pulse {
            0%, 80%, 100% { opacity: 0.3; transform: translateY(0); }
            40% { opacity: 1; transform: translateY(-2px); }
        }

        #ai-chat-error {
            display: none;
            margin: 0.4rem 1rem 0;
            color: #fda4af;
            font-size: 0.78rem;
        }

        #ai-chat-form {
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 0.55rem;
            padding: 0.85rem 1rem 1rem;
            border-top: 1px solid rgba(255, 255, 255, 0.12);
            background: rgba(4, 19, 30, 0.98);
        }

        #ai-chat-input {
            width: 100%;
            border: 1px solid rgba(255, 255, 255, 0.2);
            background: rgba(255, 255, 255, 0.08);
            color: #f8fafc;
            border-radius: 12px;
            padding: 0.68rem 0.75rem;
            font-size: 0.88rem;
            outline: none;
        }

        #ai-chat-input::placeholder {
            color: rgba(241, 245, 249, 0.6);
        }

        #ai-chat-send {
            border: none;
            border-radius: 12px;
            padding: 0.68rem 0.85rem;
            background: linear-gradient(135deg, #8b5cf6, #6d28d9);
            color: #f5f3ff;
            font-weight: 700;
            cursor: pointer;
            min-width: 78px;
        }

        #ai-chat-send:disabled {
            opacity: 0.65;
            cursor: not-allowed;
        }

        @@media (max-width: 640px) {
            #ai-chat-toggle {
                right: 14px;
                bottom: 14px;
                width: 56px;
                height: 56px;
            }

            #ai-chat-widget {
                right: 10px;
                left: 10px;
                bottom: 80px;
                width: auto;
                height: min(72vh, 500px);
            }
        }
    </style>
</head>
<body>
    <div id="mobile-nav-backdrop"></div>
    <nav id="mobile-nav-drawer" aria-label="Mobilna navigacija">
        <div class="drawer-header">
            <span class="drawer-title">Izbornik</span>
            <button id="mobile-nav-close" type="button" aria-label="Zatvori izbornik">×</button>
        </div>
        <ul class="drawer-nav">
            <li><a href="/" class="@(Context.Request.Path == "/" ? "active" : "")"><span>🏠</span><span>Nadzorna ploča</span></a></li>
            <li><a href="/appointments" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointment" ? "active" : "")"><span>📅</span><span>Termini</span></a></li>
            <li><a href="/clinics" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Clinic" ? "active" : "")"><span>🏥</span><span>Klinike</span></a></li>
            <li><a href="/medical-records" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "MedicalRecord" ? "active" : "")"><span>📋</span><span>Zdravstveni kartoni</span></a></li>
            <li><a href="/owners" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Owner" ? "active" : "")"><span>👤</span><span>Vlasnici</span></a></li>
            <li><a href="/patients" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Patient" ? "active" : "")"><span>🐾</span><span>Pacijenti</span></a></li>
            <li><a href="/services" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Service" ? "active" : "")"><span>💊</span><span>Usluge</span></a></li>
            <li><a href="/vets" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Vet" ? "active" : "")"><span>🩺</span><span>Veterinari</span></a></li>
        </ul>
    </nav>

    <div class="app-shell">
        <!-- ===== Sidebar ===== -->
        <aside class="sidebar">
            <a href="/" class="sidebar-brand">
                <div class="brand-icon">🩺</div>
                <span class="brand-text">VetAmb</span>
            </a>

            <ul class="sidebar-nav">
                <li>
                    <a href="/" class="@(Context.Request.Path == "/" ? "active" : "")">
                        <span class="nav-icon">🏠</span> Nadzorna ploča
                    </a>
                </li>

                <li class="sidebar-section-label">Upravljanje</li>

                <li>
                    <a href="/appointments" data-testid="nav-appointments" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointment" ? "active" : "")">
                        <span class="nav-icon">📅</span> Termini
                    </a>
                </li>
                <li>
                    <a href="/clinics" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Clinic" ? "active" : "")">
                        <span class="nav-icon">🏥</span> Klinike
                    </a>
                </li>
                <li>
                    <a href="/medical-records" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "MedicalRecord" ? "active" : "")">
                        <span class="nav-icon">📋</span> Zdravstveni kartoni
                    </a>
                </li>
                <li>
                    <a href="/owners" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Owner" ? "active" : "")">
                        <span class="nav-icon">👤</span> Vlasnici
                    </a>
                </li>
                <li>
                    <a href="/patients" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Patient" ? "active" : "")">
                        <span class="nav-icon">🐾</span> Pacijenti
                    </a>
                </li>
                <li>
                    <a href="/services" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Service" ? "active" : "")">
                        <span class="nav-icon">💊</span> Usluge
                    </a>
                </li>
                <li>
                    <a href="/vets" data-testid="nav-vets" class="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Vet" ? "active" : "")">
                        <span class="nav-icon">🩺</span> Veterinari
                    </a>
                </li>
            </ul>

            <!-- Mascot: pixel-art walking cat -->
            <div class="mascot-cat" aria-hidden="true">
                <div class="mascot-cat-sprite">
                    <div class="ear-l"></div>
                    <div class="ear-r"></div>
                    <div class="head"></div>
                    <div class="eye-l"></div>
                    <div class="eye-r"></div>
                    <div class="body"></div>
                    <div class="tail"></div>
                    <div class="leg-fl"></div>
                    <div class="leg-fr"></div>
                    <div class="leg-bl"></div>
                    <div class="leg-br"></div>
                </div>
            </div>
        </aside>

        <!-- ===== Main Content ===== -->
        <main class="main-content">
            <div id="global-search-container" class="d-flex flex-row align-items-center justify-content-end flex-nowrap py-2 ps-2 pe-0 w-100">
                <button id="mobile-nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav-drawer" aria-label="Otvori izbornik">&#9776;</button>
                <div id="global-search-row" class="d-flex flex-row align-items-center flex-nowrap gap-3 ms-auto">
                    <div id="global-search-wrapper">
                        <input type="text" id="global-search-input" data-testid="global-search-input" class="form-control" placeholder="Pretraži sustav..." autocomplete="off" />
                        <div id="search-results-dropdown" data-testid="global-search-dropdown"></div>
                    </div>

                    <div id="auth-controls-slot" class="d-flex align-items-center flex-nowrap" style="flex-shrink: 0;">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>

            @RenderBody()
        </main>
    </div>

    <button id="ai-chat-toggle" type="button" aria-label="Otvori AI chat pomoć">💬</button>

    <section id="ai-chat-widget" aria-label="AI chat pomoć" data-chat-user-key="@(User.Identity?.IsAuthenticated == true ? (User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? User.Identity.Name ?? "authenticated") : "anonymous")">
        <div id="ai-chat-header">
            <strong>VetAmb AI Chat Helpbot</strong>
            <div id="ai-chat-header-actions">
                <button id="ai-chat-clear" type="button" aria-label="Obriši chat">🗑</button>
                <button id="ai-chat-close" type="button" aria-label="Zatvori chat">×</button>
            </div>
        </div>
        <div id="ai-chat-messages"></div>
        <div id="ai-chat-error"></div>
        <form id="ai-chat-form">
            <input id="ai-chat-input" type="text" maxlength="1200" placeholder="Postavite pitanje o ljubimcima ili uslugama..." autocomplete="off" />
            <button id="ai-chat-send" type="submit">Pošalji</button>
        </form>
    </section>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"
            integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo="
            crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        (function () {
            const searchContainer = document.getElementById("global-search-container");
            const searchInput = document.getElementById("global-search-input");
            const dropdown = document.getElementById("search-results-dropdown");
            const mobileNavToggle = document.getElementById("mobile-nav-toggle");
            const mobileNavClose = document.getElementById("mobile-nav-close");
            const mobileNavBackdrop = document.getElementById("mobile-nav-backdrop");
            const mobileNavDrawer = document.getElementById("mobile-nav-drawer");

            if (!searchContainer || !searchInput || !dropdown) {
                return;
            }

            function closeMobileNav() {
                document.body.classList.remove("mobile-nav-open");
                if (mobileNavToggle) {
                    mobileNavToggle.setAttribute("aria-expanded", "false");
                }
            }

            function openMobileNav() {
                document.body.classList.add("mobile-nav-open");
                if (mobileNavToggle) {
                    mobileNavToggle.setAttribute("aria-expanded", "true");
                }
            }

            if (window.innerWidth > 640) {
                closeMobileNav();
            }

            if (mobileNavToggle && mobileNavClose && mobileNavBackdrop && mobileNavDrawer) {
                mobileNavToggle.addEventListener("click", function () {
                    if (document.body.classList.contains("mobile-nav-open")) {
                        closeMobileNav();
                    } else {
                        openMobileNav();
                    }
                });

                mobileNavClose.addEventListener("click", closeMobileNav);
                mobileNavBackdrop.addEventListener("click", closeMobileNav);
                mobileNavDrawer.addEventListener("click", function (event) {
                    if (event.target instanceof HTMLElement && event.target.closest("a")) {
                        closeMobileNav();
                    }
                });

                window.addEventListener("resize", function () {
                    if (window.innerWidth > 640) {
                        closeMobileNav();
                    }
                });
            }

            if (!document.getElementById('search-hover-style')) {
                document.head.insertAdjacentHTML('beforeend', '<style id="search-hover-style">#search-results-dropdown a:hover { background: rgba(0, 0, 0, 0.04) !important; text-decoration: none; }</style>');
            }

            function hideDropdown() {
                dropdown.style.display = "none";
                dropdown.innerHTML = "";
            }

            function renderResults(results) {
                dropdown.innerHTML = "";

                if (!results || results.length === 0) {
                    hideDropdown();
                    return;
                }

                results.forEach((item, index) => {
                    const normalizedType = (item.type || "item")
                        .toString()
                        .toLowerCase()
                        .replace(/\s+/g, "-")
                        .replace(/[^a-z0-9\-]/g, "");

                    let itemHtml = `
   <a href="${item.url}" data-testid="global-search-result-${normalizedType}-${index}" style="display: flex !important; justify-content: space-between; align-items: center; width: 100%; padding: 12px 20px; color: #111; text-decoration: none; border-bottom: 1px solid rgba(0,0,0,0.04); transition: background 0.2s ease;">
       <span style="font-family: 'Poppins', 'Inter', sans-serif; font-weight: 500; font-size: 0.9rem;">${item.text || ""}</span>
       <span style="background: rgba(0, 0, 0, 0.06); color: #333; font-size: 0.7rem; font-weight: 600; padding: 4px 10px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.03);">${item.type}</span>
   </a>`;

                    dropdown.insertAdjacentHTML("beforeend", itemHtml);
                });

                dropdown.style.display = "block";
            }

            let activeRequest = 0;

            searchInput.addEventListener("input", async function () {
                const term = searchInput.value.trim();

                if (term.length < 2) {
                    hideDropdown();
                    return;
                }

                const requestId = ++activeRequest;

                try {
                    const response = await fetch(`/api/search?term=${encodeURIComponent(term)}`);
                    if (!response.ok) {
                        hideDropdown();
                        return;
                    }

                    const results = await response.json();

                    if (requestId !== activeRequest) {
                        return;
                    }

                    renderResults(results);
                } catch {
                    hideDropdown();
                }
            });

            document.addEventListener("click", function (event) {
                if (!searchContainer.contains(event.target)) {
                    hideDropdown();
                }
            });
        })();

        (function () {
            const toggleBtn = document.getElementById("ai-chat-toggle");
            const chatWidget = document.getElementById("ai-chat-widget");
            const closeBtn = document.getElementById("ai-chat-close");
            const clearBtn = document.getElementById("ai-chat-clear");
            const messagesContainer = document.getElementById("ai-chat-messages");
            const errorText = document.getElementById("ai-chat-error");
            const chatForm = document.getElementById("ai-chat-form");
            const chatInput = document.getElementById("ai-chat-input");
            const sendBtn = document.getElementById("ai-chat-send");

            if (!toggleBtn || !chatWidget || !closeBtn || !clearBtn || !messagesContainer || !errorText || !chatForm || !chatInput || !sendBtn) {
                return;
            }

            const welcome = "Bok. Ja sam VetAmb AI pomoćnik. Pitajte me o njezi ljubimaca ili našim uslugama.";
            const storagePrefix = "vetamb:chat:history:";
            const activeUserStorageKey = "vetamb:chat:active-user";
            const openStateStorageKey = "vetamb:chat:is-open";
            const currentUserKey = (chatWidget.getAttribute("data-chat-user-key") || "anonymous").trim() || "anonymous";
            const historyStorageKey = `${storagePrefix}${currentUserKey}`;
            const messageHistory = [];
            const defaultSendLabel = sendBtn.textContent;

            function hasStorage() {
                try {
                    const key = "vetamb:chat:test";
                    localStorage.setItem(key, "1");
                    localStorage.removeItem(key);
                    return true;
                } catch {
                    return false;
                }
            }

            const canUseStorage = hasStorage();

            function clearAllStoredHistories() {
                if (!canUseStorage) {
                    return;
                }

                const keysToDelete = [];
                for (let i = 0; i < localStorage.length; i++) {
                    const key = localStorage.key(i);
                    if (key && key.startsWith(storagePrefix)) {
                        keysToDelete.push(key);
                    }
                }

                keysToDelete.forEach(function (key) {
                    localStorage.removeItem(key);
                });
            }

            function saveHistory() {
                if (!canUseStorage) {
                    return;
                }

                localStorage.setItem(historyStorageKey, JSON.stringify(messageHistory));
            }

            function loadHistory() {
                if (!canUseStorage) {
                    return [];
                }

                const raw = localStorage.getItem(historyStorageKey);
                if (!raw) {
                    return [];
                }

                try {
                    const parsed = JSON.parse(raw);
                    if (!Array.isArray(parsed)) {
                        return [];
                    }

                    return parsed
                        .filter(item => item && (item.role === "user" || item.role === "assistant") && typeof item.content === "string")
                        .map(item => ({ role: item.role, content: item.content.trim() }))
                        .filter(item => item.content.length > 0);
                } catch {
                    return [];
                }
            }

            function setError(message) {
                errorText.textContent = message || "";
                errorText.style.display = message ? "block" : "none";
            }

            function setLoading(isLoading) {
                sendBtn.disabled = isLoading;
                chatInput.disabled = isLoading;
                sendBtn.textContent = isLoading ? "..." : defaultSendLabel;
            }

            function scrollToBottom() {
                messagesContainer.scrollTop = messagesContainer.scrollHeight;
            }

            function createMessageBubble(role, content) {
                const row = document.createElement("div");
                row.className = `ai-chat-row ${role}`;

                const bubble = document.createElement("div");
                bubble.className = "ai-chat-bubble";
                bubble.textContent = content;

                row.appendChild(bubble);
                messagesContainer.appendChild(row);
                scrollToBottom();

                return bubble;
            }

            function renderHistory(history) {
                messagesContainer.innerHTML = "";
                history.forEach(function (item) {
                    createMessageBubble(item.role, item.content);
                });
            }

            function resetChat(seedWelcome) {
                messageHistory.splice(0, messageHistory.length);
                messagesContainer.innerHTML = "";
                setError("");

                if (seedWelcome) {
                    messageHistory.push({ role: "assistant", content: welcome });
                    createMessageBubble("assistant", welcome);
                }

                saveHistory();
            }

            function createTypingBubble() {
                const row = document.createElement("div");
                row.className = "ai-chat-row assistant";

                const bubble = document.createElement("div");
                bubble.className = "ai-chat-bubble";

                const typing = document.createElement("span");
                typing.className = "ai-chat-typing";
                typing.innerHTML = "<span></span><span></span><span></span>";

                bubble.appendChild(typing);
                row.appendChild(bubble);
                messagesContainer.appendChild(row);
                scrollToBottom();

                return row;
            }

            async function typeText(bubble, text) {
                bubble.textContent = "";

                for (let i = 0; i < text.length; i++) {
                    bubble.textContent += text[i];
                    if (i % 3 === 0) {
                        scrollToBottom();
                        await new Promise(resolve => setTimeout(resolve, 12));
                    }
                }

                scrollToBottom();
            }

            function openChat() {
                chatWidget.classList.add("open");
                toggleBtn.setAttribute("aria-expanded", "true");
                if (canUseStorage) {
                    localStorage.setItem(openStateStorageKey, "1");
                }
                requestAnimationFrame(function () {
                    scrollToBottom();
                });
                setTimeout(function () { chatInput.focus(); }, 40);
            }

            function closeChat() {
                chatWidget.classList.remove("open");
                toggleBtn.setAttribute("aria-expanded", "false");
                if (canUseStorage) {
                    localStorage.setItem(openStateStorageKey, "0");
                }
            }

            async function sendMessage() {
                const text = (chatInput.value || "").trim();
                if (!text) {
                    return;
                }

                setError("");
                chatInput.value = "";

                messageHistory.push({ role: "user", content: text });
                createMessageBubble("user", text);
                saveHistory();

                setLoading(true);
                const typingRow = createTypingBubble();

                try {
                    const response = await fetch("/api/chat", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json"
                        },
                        body: JSON.stringify(messageHistory)
                    });

                    const payload = await response.json().catch(function () { return {}; });
                    typingRow.remove();

                    if (!response.ok) {
                        const message = payload.message || "Došlo je do pogreške pri komunikaciji s AI pomoćnikom.";
                        setError(message);
                        createMessageBubble("assistant", "Nažalost, trenutno nisam dostupan. Pokušajte ponovno za nekoliko trenutaka.");
                        return;
                    }

                    const aiText = (payload.response || "").toString().trim();
                    if (!aiText) {
                        setError("AI pomoćnik nije vratio odgovor.");
                        return;
                    }

                    const assistantBubble = createMessageBubble("assistant", "");
                    await typeText(assistantBubble, aiText);

                    messageHistory.push({ role: "assistant", content: aiText });
                    saveHistory();
                } catch {
                    typingRow.remove();
                    setError("Mrežna pogreška. Provjerite vezu i pokušajte ponovno.");
                    createMessageBubble("assistant", "Ne mogu se povezati na AI pomoćnika. Pokušajte ponovno.");
                } finally {
                    setLoading(false);
                    chatInput.focus();
                }
            }

            toggleBtn.addEventListener("click", function () {
                if (chatWidget.classList.contains("open")) {
                    closeChat();
                } else {
                    openChat();
                }
            });

            closeBtn.addEventListener("click", closeChat);

            clearBtn.addEventListener("click", function () {
                resetChat(true);
            });

            chatForm.addEventListener("submit", async function (event) {
                event.preventDefault();
                await sendMessage();
            });

            chatInput.addEventListener("keydown", async function (event) {
                if (event.key === "Enter") {
                    event.preventDefault();
                    await sendMessage();
                }
            });

            if (canUseStorage) {
                const previousUserKey = localStorage.getItem(activeUserStorageKey);
                if (previousUserKey && previousUserKey !== currentUserKey) {
                    clearAllStoredHistories();
                }

                localStorage.setItem(activeUserStorageKey, currentUserKey);
            }

            const storedHistory = loadHistory();
            if (storedHistory.length > 0) {
                storedHistory.forEach(item => messageHistory.push(item));
                renderHistory(messageHistory);
                setTimeout(function () {
                    scrollToBottom();
                }, 0);
            } else {
                resetChat(true);
            }

            if (canUseStorage && localStorage.getItem(openStateStorageKey) === "1") {
                openChat();
            }
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
