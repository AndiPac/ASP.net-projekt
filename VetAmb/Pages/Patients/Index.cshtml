@page
@model VetAmb.Pages.Patients.IndexModel
@{
    ViewData["Title"] = "Patients";
}

<!-- Breadcrumbs -->
<nav class="breadcrumbs">
    <a asp-page="/Index">Dashboard</a>
    <span class="separator">/</span>
    <span class="current">Patients</span>
</nav>

<!-- Page Header -->
<div class="page-header">
    <h1>Patients</h1>
    <p class="subtitle">Browse all registered patients across clinics</p>
</div>

<!-- Patient Cards — CSS Grid -->
<div class="card-grid">
    @foreach (var patient in Model.Patients)
    {
        var speciesLower = patient.Species.ToString().ToLower();
        var speciesEmoji = patient.Species switch
        {
            AnimalSpecies.Dog => "🐕",
            AnimalSpecies.Cat => "🐈",
            AnimalSpecies.Bird => "🐦",
            AnimalSpecies.Rabbit => "🐇",
            AnimalSpecies.Hamster => "🐹",
            AnimalSpecies.Guinea_Pig => "🐹",
            AnimalSpecies.Ferret => "🦦",
            AnimalSpecies.Reptile => "🦎",
            _ => "🐾"
        };
        var avatarClass = patient.Species switch
        {
            AnimalSpecies.Dog => "dog",
            AnimalSpecies.Cat => "cat",
            AnimalSpecies.Bird => "bird",
            AnimalSpecies.Rabbit => "rabbit",
            AnimalSpecies.Hamster => "hamster",
            _ => "default"
        };

        <a asp-page="Details" asp-route-id="@patient.Id" class="glass-card-link">
            <div class="glass-card patient-card">
                <div class="card-top">
                    <div class="avatar @avatarClass">@speciesEmoji</div>
                    <div>
                        <div class="card-name">@patient.Name</div>
                        <div class="card-breed">@patient.Breed</div>
                    </div>
                    <span class="species-badge @avatarClass" style="margin-left:auto;">
                        @patient.Species
                    </span>
                </div>

                <div class="card-details">
                    <div class="detail-item">
                        <span class="detail-label">Weight</span>
                        <span class="detail-value">@patient.Weight kg</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Color</span>
                        <span class="detail-value">@patient.Color</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Born</span>
                        <span class="detail-value">@patient.DateOfBirth.ToString("MMM dd, yyyy")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Microchip</span>
                        <span class="detail-value">@patient.MicrochipId</span>
                    </div>
                </div>

                <div class="card-footer">
                    <span class="owner-tag">👤 @patient.Owner?.FirstName @patient.Owner?.LastName</span>
                    <span class="view-link">DETAILS →</span>
                </div>
            </div>
        </a>
    }
</div>
