@model List<MedicalRecord>
@{
    ViewData["Title"] = "Medicinski Zapisi";
    var canManage = User.IsInRole("Administrator") || User.IsInRole("Vet");
}

<nav class="breadcrumbs">
    <a href="/">Nadzorna plo&#269;a</a>
    <span class="separator">/</span>
    <span class="current">Medicinski Zapisi</span>
</nav>

<div class="page-header">
    <h1>Medicinski Zapisi</h1>
    <p class="subtitle">Svi medicinski zapisi pacijenata</p>
</div>

@if (canManage)
{
<div class="page-actions">
    <a href="/medical-records/create" class="btn-primary">&#43; Novi Zapis</a>
</div>
}

<div class="card-grid">
    @foreach (var record in Model.OrderByDescending(r => r.RecordDate))
    {
        <div class="glass-card patient-card" style="position:relative;">
            <a href="/medical-records/@record.Id" class="glass-card-link-inner">
                <div class="card-top">
                    <div class="avatar blue" style="background:linear-gradient(135deg,rgba(108,99,255,0.35),rgba(108,99,255,0.1));">&#128203;</div>
                    <div>
                        <div class="card-name">@record.Diagnosis</div>
                        <div class="card-breed">@record.RecordDate.ToString("d")</div>
                    </div>
                </div>

                <div class="card-details">
                    <div class="detail-item">
                        <span class="detail-label">Terapija</span>
                        <span class="detail-value">@record.Treatment</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Pacijent</span>
                        <span class="detail-value">@record.Patient?.Name</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Datum</span>
                        <span class="detail-value">@record.RecordDate.ToString("d")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Napomene</span>
                        <span class="detail-value">@(string.IsNullOrWhiteSpace(record.Notes) ? "—" : (record.Notes.Length > 30 ? record.Notes.Substring(0, 30) + "..." : record.Notes))</span>
                    </div>
                </div>

            </a>

            @if (canManage)
            {
            <div class="card-actions">
                <a href="/medical-records/@record.Id/edit" class="btn-edit">&#9999; Uredi</a>
                <form action="/medical-records/@record.Id/delete" method="post"
                      onsubmit="return confirm('Jeste li sigurni da želite ukloniti zapis @Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(record.Diagnosis ?? ""))?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-danger">&#128465; Obriši</button>
                </form>
            </div>
            }
        </div>
    }
</div>
