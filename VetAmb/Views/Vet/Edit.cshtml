@model VetAmb.ViewModels.VetFormModel
@using VetAmb.Models
@{
    ViewData["Title"] = "Uredi veterinara – Dr. " + Model.FirstName + " " + Model.LastName;
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<nav class="breadcrumbs">
    <a href="/">Nadzorna plo&#269;a</a>
    <span class="separator">/</span>
    <a href="/vets">Veterinari</a>
    <span class="separator">/</span>
    <a href="/vets/@Model.Id">Dr. @Model.FirstName @Model.LastName</a>
    <span class="separator">/</span>
    <span class="current">Uredi</span>
</nav>

<div class="page-actions">
    <div class="page-header" style="margin-bottom:0;">
        <h1>&#9999; Uredi veterinara</h1>
        <p class="subtitle">Ažurirajte podatke Dr. @Model.FirstName @Model.LastName</p>
    </div>
    <a href="/vets/@Model.Id" class="btn-back">&#8592; Natrag</a>
</div>

<form asp-action="Edit" asp-controller="Vet" asp-route-id="@Model.Id"
      method="post" class="form-glass">
    @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <!-- Row 1: FirstName + LastName -->
        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="FirstName">Ime</label>
                <input asp-for="FirstName" class="form-input" placeholder="Npr. Ivan" />
                <span asp-validation-for="FirstName" class="form-validation"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="LastName">Prezime</label>
                <input asp-for="LastName" class="form-input" placeholder="Npr. Kovač" />
                <span asp-validation-for="LastName" class="form-validation"></span>
            </div>
        </div>

        <!-- Row 2: Specialization + LicenseNumber -->
        <div class="form-row">
            <div class="form-group">
                @await Html.PartialAsync("_AjaxAutocomplete",
                    new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
                    {
                        ["FieldName"]   = "Specialization",
                        ["FieldId"]     = "specialization",
                        ["LabelText"]   = "Specijalizacija",
                        ["Endpoint"]    = "/vets/search-specialization",
                        ["Placeholder"] = "Upišite specijalizaciju...",
                        ["InitialId"]   = (int)Model.Specialization,
                        ["InitialText"] = ViewBag.InitialSpecializationText as string ?? "",
                        ["MinId"]       = 0
                    })
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="LicenseNumber">Broj licence</label>
                <input asp-for="LicenseNumber" class="form-input" placeholder="Npr. VET-2024-001" />
                <span asp-validation-for="LicenseNumber" class="form-validation"></span>
            </div>
        </div>

        <!-- Row 3: YearsOfExperience + Phone -->
        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="YearsOfExperience">Godine iskustva</label>
                <input asp-for="YearsOfExperience" type="number"
                       class="form-input" placeholder="Npr. 5" />
                <span asp-validation-for="YearsOfExperience" class="form-validation"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Phone">Telefon</label>
                <input asp-for="Phone" class="form-input" placeholder="Npr. 091 234 5678" />
                <span asp-validation-for="Phone" class="form-validation"></span>
            </div>
        </div>

        <!-- Row 4: HourlyRate + Clinic AJAX Autocomplete (pre-populated) -->
        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="HourlyRate">Satnica (€)</label>
                <input asp-for="HourlyRate" type="number" step="0.01"
                       class="form-input" placeholder="Npr. 75.00" />
                <span asp-validation-for="HourlyRate" class="form-validation"></span>
            </div>
            <div class="form-group">
                @await Html.PartialAsync("_AjaxAutocomplete",
                    new Microsoft.AspNetCore.Mvc.ViewFeatures.ViewDataDictionary(ViewData)
                    {
                        ["FieldName"]   = "ClinicId",
                        ["FieldId"]     = "clinicId",
                        ["LabelText"]   = "Klinika",
                        ["Endpoint"]    = "/vets/search-clinics",
                        ["Placeholder"] = "Upišite naziv klinike...",
                        ["InitialId"]   = Model.ClinicId > 0 ? (object)Model.ClinicId : null,
                        ["InitialText"] = ViewBag.InitialClinicText as string ?? "",
                        ["RequiredMessage"] = "Odabir klinike je obavezan."
                    })
            </div>
        </div>

    <div class="form-footer">
        <a href="/vets/@Model.Id" class="btn-secondary">Odustani</a>
        <button type="submit" class="btn-primary">&#128190; Spremi Izmjene</button>
    </div>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
