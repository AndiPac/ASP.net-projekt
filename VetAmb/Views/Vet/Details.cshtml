@model Vet
@{
    ViewData["Title"] = $"Dr. {Model.FirstName} {Model.LastName}";
}

<nav class="breadcrumbs">
    <a href="/">Nadzorna plo&#269;a</a>
    <span class="separator">/</span>
    <a href="/vets">Veterinari</a>
    <span class="separator">/</span>
    <span class="current">Dr. @Model.FirstName @Model.LastName</span>
</nav>

<a href="/vets" class="btn-back">&#8592; Natrag na Veterinare</a>

<div class="card-actions" style="margin-bottom:1.5rem;">
    <a href="/vets/@Model.Id/edit" class="btn-edit">&#9999; Uredi</a>
    <form action="/vets/@Model.Id/delete" method="post"
          onsubmit="return confirm('Jeste li sigurni da želite ukloniti veterinara Dr. @Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(Model.FirstName + " " + Model.LastName))?');">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn-danger">&#128465; Obriši</button>
    </form>
</div>

<div class="details-grid">
    <div class="glass-card details-hero">
        <div class="hero-avatar" style="width:100px;height:100px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:3rem;background:linear-gradient(135deg,rgba(108,99,255,0.35),rgba(108,99,255,0.1));margin-bottom:1.25rem;">&#129657;</div>
        <div class="hero-name">Dr. @Model.FirstName @Model.LastName</div>
        <div class="hero-breed">@Model.Specialization.GetDisplayName()</div>

        <div class="info-grid" style="width:100%;">
            <div class="info-item">
                <div class="info-label">Licenca</div>
                <div class="info-value">@Model.LicenseNumber</div>
            </div>
            <div class="info-item">
                <div class="info-label">Iskustvo</div>
                <div class="info-value">@Model.YearsOfExperience godina</div>
            </div>
            <div class="info-item">
                <div class="info-label">Satnica</div>
                <div class="info-value">@Model.HourlyRate &#8364;</div>
            </div>
            <div class="info-item">
                <div class="info-label">Telefon</div>
                <div class="info-value">@Model.Phone</div>
            </div>
        </div>
    </div>

    <div>
        <div class="glass-card" style="margin-bottom:1.5rem;">
            <h3 class="section-title">&#127973; Klinika</h3>
            @if (Model.Clinic != null)
            {
                <a href="/clinics/@Model.Clinic.Id" class="timeline-link">
                    <div class="timeline-item">
                        <div class="timeline-date" style="background:rgba(0,188,212,0.15);">
                            <span class="day" style="font-size:1.3rem;">&#127973;</span>
                        </div>
                        <div class="timeline-body" style="flex:1;">
                            <div class="tl-reason">@Model.Clinic.Name</div>
                            <div class="tl-vet">@Model.Clinic.Address &middot; @Model.Clinic.Phone</div>
                        </div>
                    </div>
                </a>
            }
            else
            {
                <div class="empty-state">Nema dodijeljene klinike.</div>
            }
        </div>

        <div class="glass-card">
            <h3 class="section-title">&#128197; Termini</h3>
            @if (Model.Appointments.Any())
            {
                @foreach (var appt in Model.Appointments.OrderByDescending(a => a.AppointmentDateTime))
                {
                    var statusClass = appt.Status switch
                    {
                        AppointmentStatus.Completed   => "completed",
                        AppointmentStatus.Scheduled   => "scheduled",
                        AppointmentStatus.InProgress  => "inprogress",
                        AppointmentStatus.Cancelled   => "cancelled",
                        AppointmentStatus.NoShow      => "noshow",
                        AppointmentStatus.Rescheduled => "rescheduled",
                        _ => ""
                    };
                    <a href="/appointments/@appt.Id" class="timeline-link">
                        <div class="timeline-item">
                            <div class="timeline-date">
                                <span class="day">@appt.AppointmentDateTime.Day</span>
                                <span class="month">@appt.AppointmentDateTime.ToString("MMM")</span>
                            </div>
                            <div class="timeline-body" style="flex:1;">
                                <div class="tl-reason">@appt.Patient?.Name &#8212; @appt.Reason</div>
                                <span class="status-badge @statusClass">@appt.Status.GetDisplayName()</span>
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="empty-state">Nema evidentiranih termina.</div>
            }
        </div>
    </div>
</div>

