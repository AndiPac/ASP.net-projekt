@model List<Vet>
@{
    ViewData["Title"] = "Veterinari";
    var canManage = User.IsInRole("Administrator");
}

<nav class="breadcrumbs">
    <a href="/">Nadzorna plo&#269;a</a>
    <span class="separator">/</span>
    <span class="current">Veterinari</span>
</nav>

<div class="page-header">
    <h1>Veterinari</h1>
    <p class="subtitle">Svi registrirani veterinari po klinikama</p>
</div>

@if (canManage)
{
<div class="page-actions">
    <a href="/vets/create" class="btn-primary">&#43; Novi Veterinar</a>
</div>
}

<section class="glass-card" style="padding:1rem; margin-bottom:1rem;">
    <label for="vetFilterInput" class="form-label">Filtriraj veterinare</label>
    <input id="vetFilterInput" data-testid="vets-filter-input" type="text" class="form-input" placeholder="Upišite ime, prezime, specijalizaciju ili licencu..." />
</section>

<div class="card-grid">
    @foreach (var vet in Model)
    {
        var specColor = vet.Specialization switch
        {
            VeterinarySpecialization.GeneralPractice => "blue",
            VeterinarySpecialization.Surgery => "pink",
            VeterinarySpecialization.Cardiology => "pink",
            VeterinarySpecialization.Dentistry => "cyan",
            VeterinarySpecialization.Dermatology => "orange",
            VeterinarySpecialization.Orthopedics => "green",
            VeterinarySpecialization.InternalMedicine => "blue",
            _ => "blue"
        };

           <div class="glass-card patient-card vet-card"
               data-testid="vet-card-@vet.Id"
               data-vet-search="@($"{vet.FirstName} {vet.LastName} {vet.Specialization.GetDisplayName()} {vet.LicenseNumber}".ToLowerInvariant())"
               style="position:relative;">
            <a href="/vets/@vet.Id" class="glass-card-link-inner">
                <div class="card-top">
                    <div class="avatar @specColor" style="background:linear-gradient(135deg,rgba(108,99,255,0.35),rgba(108,99,255,0.1));">&#129657;</div>
                    <div>
                        <div class="card-name">Dr. @vet.FirstName @vet.LastName</div>
                        <div class="card-breed">@vet.Specialization.GetDisplayName()</div>
                    </div>
                </div>

                <div class="card-details">
                    <div class="detail-item">
                        <span class="detail-label">Licenca</span>
                        <span class="detail-value">@vet.LicenseNumber</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Iskustvo</span>
                        <span class="detail-value">@vet.YearsOfExperience god.</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Satnica</span>
                        <span class="detail-value">@vet.HourlyRate &#8364;/h</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Telefon</span>
                        <span class="detail-value">@vet.Phone</span>
                    </div>
                </div>

            </a>

            @if (canManage)
            {
            <div class="card-actions">
                <a href="/vets/@vet.Id/edit" class="btn-edit">&#9999; Uredi</a>
                <form action="/vets/@vet.Id/delete" method="post"
                      onsubmit="return confirm('Jeste li sigurni da želite ukloniti veterinara Dr. @Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(vet.FirstName + " " + vet.LastName))?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-danger">&#128465; Obriši</button>
                </form>
            </div>
            }
        </div>
    }
</div>

<div class="glass-card" data-testid="vets-filter-empty" style="display:none; padding:1rem; margin-top:0.75rem; text-align:center; opacity:0.85;">
    Nema rezultata za traženi pojam.
</div>

@section Scripts {
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        const filterInput = document.querySelector('[data-testid="vets-filter-input"]');
        const vetCards = Array.from(document.querySelectorAll('.vet-card'));
        const emptyState = document.querySelector('[data-testid="vets-filter-empty"]');

        if (!filterInput || vetCards.length === 0) {
            return;
        }

        function updateEmptyState() {
            const visibleCount = vetCards.filter(function (card) {
                return card.style.display !== 'none';
            }).length;

            if (emptyState) {
                emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
            }
        }

        filterInput.addEventListener('input', function () {
            const term = (filterInput.value || '').trim().toLowerCase();

            vetCards.forEach(function (card) {
                const searchable = (card.getAttribute('data-vet-search') || '').toLowerCase();
                const isVisible = term.length === 0 || searchable.includes(term);
                card.style.display = isVisible ? '' : 'none';
            });

            updateEmptyState();
        });

        updateEmptyState();
    });
    </script>
}

