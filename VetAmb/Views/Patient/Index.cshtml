@model List<Patient>
@{
    ViewData["Title"] = "Pacijenti";
    var canManage = User.IsInRole("Administrator") || User.IsInRole("Vet");
}

<nav class="breadcrumbs">
    <a href="/">Nadzorna ploča</a>
    <span class="separator">/</span>
    <span class="current">Pacijenti</span>
</nav>

<div class="page-header">
    <h1>Pacijenti</h1>
    <p class="subtitle">Pregled svih registriranih pacijenata kroz klinike</p>
</div>

@if (canManage)
{
<div class="page-actions">
    <a href="/patients/create" class="btn-primary">&#43; Novi Pacijent</a>
</div>
}

<section class="glass-card" style="padding:1rem; margin-bottom:1rem;">
    <label for="patientFilterInput" class="form-label">Filtriraj pacijente</label>
    <input id="patientFilterInput" data-testid="patients-filter-input" type="text" class="form-input" placeholder="Upišite ime, vrstu, pasminu, boju ili mikročip..." />
</section>

<div class="card-grid">
    @foreach (var patient in Model)
    {
        var speciesEmoji = patient.Species switch
        {
            AnimalSpecies.Dog => "🐕",
            AnimalSpecies.Cat => "🐈",
            AnimalSpecies.Bird => "🐦",
            AnimalSpecies.Rabbit => "🐇",
            AnimalSpecies.Hamster => "🐹",
            _ => "🐾"
        };
        var avatarClass = patient.Species switch
        {
            AnimalSpecies.Dog => "dog",
            AnimalSpecies.Cat => "cat",
            AnimalSpecies.Bird => "bird",
            AnimalSpecies.Rabbit => "rabbit",
            AnimalSpecies.Hamster => "hamster",
            _ => "default"
        };

        var searchable = $"{patient.Name} {patient.Species.GetDisplayName()} {patient.Breed} {patient.Color} {patient.MicrochipId}".ToLowerInvariant();

        <div class="glass-card patient-card searchable-patient-card" data-patient-search="@searchable" style="position:relative;">
            <a href="/patients/@patient.Id" class="glass-card-link-inner">
                <div class="card-top">
                    <div class="avatar @avatarClass">@speciesEmoji</div>
                    <div>
                        <div class="card-name">@patient.Name</div>
                        <div class="card-breed">@patient.Breed</div>
                    </div>
                    <span class="species-badge @avatarClass">@patient.Species.GetDisplayName()</span>
                </div>
                <div class="card-details">
                    <div class="detail-item">
                        <span class="detail-label">Težina</span>
                        <span class="detail-value">@patient.Weight kg</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Boja</span>
                        <span class="detail-value">@patient.Color</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Rođen</span>
                        <span class="detail-value">@patient.DateOfBirth.ToString("d")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Mikročip</span>
                        <span class="detail-value">@patient.MicrochipId</span>
                    </div>
                </div>
            </a>

            @if (canManage)
            {
            <div class="card-actions">
                <a href="/patients/@patient.Id/edit" class="btn-edit">&#9999; Uredi</a>
                <form action="/patients/@patient.Id/delete" method="post"
                      onsubmit="return confirm('Jeste li sigurni da želite ukloniti pacijenta @Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(patient.Name ?? ""))?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-danger">&#128465; Obriši</button>
                </form>
            </div>
            }
        </div>
    }
</div>

<div class="glass-card" data-testid="patients-filter-empty" style="display:none; padding:1rem; margin-top:0.75rem; text-align:center; opacity:0.85;">
    Nema rezultata za traženi pojam.
</div>

@section Scripts {
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        const filterInput = document.querySelector('[data-testid="patients-filter-input"]');
        const cards = Array.from(document.querySelectorAll('.searchable-patient-card'));
        const emptyState = document.querySelector('[data-testid="patients-filter-empty"]');

        if (!filterInput || cards.length === 0) {
            return;
        }

        function updateEmptyState() {
            const visibleCount = cards.filter(function (card) {
                return card.style.display !== 'none';
            }).length;

            if (emptyState) {
                emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
            }
        }

        filterInput.addEventListener('input', function () {
            const term = (filterInput.value || '').trim().toLowerCase();

            cards.forEach(function (card) {
                const searchable = (card.getAttribute('data-patient-search') || '').toLowerCase();
                const isVisible = term.length === 0 || searchable.includes(term);
                card.style.display = isVisible ? '' : 'none';
            });

            updateEmptyState();
        });

        updateEmptyState();
    });
    </script>
}
