@model List<Service>
@{
    ViewData["Title"] = "Usluge";
    var canManage = User.IsInRole("Administrator");
}

<nav class="breadcrumbs">
    <a href="/">Nadzorna plo&#269;a</a>
    <span class="separator">/</span>
    <span class="current">Usluge</span>
</nav>

<div class="page-header">
    <h1>Usluge</h1>
    <p class="subtitle">Sve dostupne veterinarske usluge</p>
</div>

@if (canManage)
{
<div class="page-actions">
    <a href="/services/create" class="btn-primary">&#43; Nova Usluga</a>
</div>
}

<section class="glass-card" style="padding:1rem; margin-bottom:1rem;">
    <label for="servicesFilterInput" class="form-label">Filtriraj usluge</label>
    <input id="servicesFilterInput" data-testid="services-filter-input" type="text" class="form-input" placeholder="Upišite naziv usluge, opis, cijenu ili trajanje..." />
</section>

<div class="card-grid">
    @foreach (var service in Model)
    {
        var searchable = $"{service.Name} {service.Description} {service.Price} {service.EstimatedDurationMinutes}".ToLowerInvariant();

        <div class="glass-card patient-card service-card" data-service-search="@searchable" style="position:relative;">
            <a href="/services/@service.Id" class="glass-card-link-inner">
                <div class="card-top">
                    <div class="avatar green" style="background:linear-gradient(135deg,rgba(0,230,118,0.35),rgba(0,230,118,0.1));">&#128138;</div>
                    <div>
                        <div class="card-name">@service.Name</div>
                        <div class="card-breed">@service.Description</div>
                    </div>
                </div>

                <div class="card-details">
                    <div class="detail-item">
                        <span class="detail-label">Cijena</span>
                        <span class="detail-value">@service.Price &#8364;</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Trajanje</span>
                        <span class="detail-value">@service.EstimatedDurationMinutes min</span>
                    </div>
                </div>

            </a>

            @if (canManage)
            {
            <div class="card-actions">
                <a href="/services/@service.Id/edit" class="btn-edit">&#9999; Uredi</a>
                <form action="/services/@service.Id/delete" method="post"
                      onsubmit="return confirm('Jeste li sigurni da želite ukloniti uslugu @Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(service.Name ?? ""))?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-danger">&#128465; Obriši</button>
                </form>
            </div>
            }
        </div>
    }
</div>

<div class="glass-card" data-testid="services-filter-empty" style="display:none; padding:1rem; margin-top:0.75rem; text-align:center; opacity:0.85;">
    Nema rezultata za traženi pojam.
</div>

@section Scripts {
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        const filterInput = document.querySelector('[data-testid="services-filter-input"]');
        const cards = Array.from(document.querySelectorAll('.service-card'));
        const emptyState = document.querySelector('[data-testid="services-filter-empty"]');

        if (!filterInput || cards.length === 0) {
            return;
        }

        function updateEmptyState() {
            const visibleCount = cards.filter(function (card) {
                return card.style.display !== 'none';
            }).length;

            if (emptyState) {
                emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
            }
        }

        filterInput.addEventListener('input', function () {
            const term = (filterInput.value || '').trim().toLowerCase();

            cards.forEach(function (card) {
                const searchable = (card.getAttribute('data-service-search') || '').toLowerCase();
                const isVisible = term.length === 0 || searchable.includes(term);
                card.style.display = isVisible ? '' : 'none';
            });

            updateEmptyState();
        });

        updateEmptyState();
    });
    </script>
}

