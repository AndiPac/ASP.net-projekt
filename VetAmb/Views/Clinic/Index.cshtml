@model List<Clinic>
@{
    ViewData["Title"] = "Klinike";
    var canManage = User.IsInRole("Administrator");
}

<nav class="breadcrumbs">
    <a href="/">Nadzorna plo&#269;a</a>
    <span class="separator">/</span>
    <span class="current">Klinike</span>
</nav>

<div class="page-header">
    <h1>Klinike</h1>
    <p class="subtitle">Sve registrirane veterinarske klinike</p>
</div>

@if (canManage)
{
<div class="page-actions">
    <a href="/clinics/create" class="btn-primary">&#43; Nova Klinika</a>
</div>
}

<section class="glass-card" style="padding:1rem; margin-bottom:1rem;">
    <label for="clinicFilterInput" class="form-label">Filtriraj klinike</label>
    <input id="clinicFilterInput" data-testid="clinics-filter-input" type="text" class="form-input" placeholder="Upišite naziv, adresu, email, telefon ili registracijski broj..." />
</section>

<div class="card-grid">
    @foreach (var clinic in Model)
    {
        var searchable = $"{clinic.Name} {clinic.Address} {clinic.Phone} {clinic.Email} {clinic.RegistrationNumber}".ToLowerInvariant();

        <div class="glass-card patient-card clinic-card" data-clinic-search="@searchable" style="position:relative;">
            <a href="/clinics/@clinic.Id" class="glass-card-link-inner">
                <div class="card-top">
                    <div class="avatar cyan" style="background:linear-gradient(135deg,rgba(0,188,212,0.35),rgba(0,188,212,0.1));">&#127973;</div>
                    <div>
                        <div class="card-name">@clinic.Name</div>
                        <div class="card-breed">@clinic.Address</div>
                    </div>
                </div>

                <div class="card-details">
                    <div class="detail-item">
                        <span class="detail-label">Telefon</span>
                        <span class="detail-value">@clinic.Phone</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Email</span>
                        <span class="detail-value">@clinic.Email</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Osnovana</span>
                        <span class="detail-value">@clinic.FoundationDate.ToString("MM/yyyy")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Kapacitet</span>
                        <span class="detail-value">@clinic.MaxCapacity</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Reg. br.</span>
                        <span class="detail-value">@clinic.RegistrationNumber</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Veterinari</span>
                        <span class="detail-value">@clinic.Vets.Count</span>
                    </div>
                </div>

            </a>

            @if (canManage)
            {
            <div class="card-actions">
                <a href="/clinics/@clinic.Id/edit" class="btn-edit">&#9999; Uredi</a>
                <form action="/clinics/@clinic.Id/delete" method="post"
                      onsubmit="return confirm('Jeste li sigurni da želite ukloniti kliniku @Html.Raw(System.Text.Encodings.Web.JavaScriptEncoder.Default.Encode(clinic.Name ?? ""))?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn-danger">&#128465; Obriši</button>
                </form>
            </div>
            }
        </div>
    }
</div>

<div class="glass-card" data-testid="clinics-filter-empty" style="display:none; padding:1rem; margin-top:0.75rem; text-align:center; opacity:0.85;">
    Nema rezultata za traženi pojam.
</div>

@section Scripts {
    <script>
    document.addEventListener('DOMContentLoaded', function () {
        const filterInput = document.querySelector('[data-testid="clinics-filter-input"]');
        const cards = Array.from(document.querySelectorAll('.clinic-card'));
        const emptyState = document.querySelector('[data-testid="clinics-filter-empty"]');

        if (!filterInput || cards.length === 0) {
            return;
        }

        function updateEmptyState() {
            const visibleCount = cards.filter(function (card) {
                return card.style.display !== 'none';
            }).length;

            if (emptyState) {
                emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
            }
        }

        filterInput.addEventListener('input', function () {
            const term = (filterInput.value || '').trim().toLowerCase();

            cards.forEach(function (card) {
                const searchable = (card.getAttribute('data-clinic-search') || '').toLowerCase();
                const isVisible = term.length === 0 || searchable.includes(term);
                card.style.display = isVisible ? '' : 'none';
            });

            updateEmptyState();
        });

        updateEmptyState();
    });
    </script>
}
