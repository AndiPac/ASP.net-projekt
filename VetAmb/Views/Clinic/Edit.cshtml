@model VetAmb.ViewModels.ClinicFormModel
@{
    ViewData["Title"] = "Uredi kliniku – " + Model.Name;
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<nav class="breadcrumbs">
    <a href="/">Nadzorna plo&#269;a</a>
    <span class="separator">/</span>
    <a href="/clinics">Klinike</a>
    <span class="separator">/</span>
    <a href="/clinics/@Model.Id">@Model.Name</a>
    <span class="separator">/</span>
    <span class="current">Uredi</span>
</nav>

<div class="page-actions">
    <div class="page-header" style="margin-bottom:0;">
        <h1>&#9999; Uredi kliniku</h1>
        <p class="subtitle">Ažurirajte podatke klinike @Model.Name</p>
    </div>
    <a href="/clinics/@Model.Id" class="btn-back">&#8592; Natrag</a>
</div>

<form asp-action="Edit" asp-controller="Clinic" asp-route-id="@Model.Id"
      method="post" class="form-glass">
    @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <!-- Row 1: Name -->
        <div class="form-group">
            <label class="form-label" asp-for="Name">Naziv klinike</label>
            <input asp-for="Name" class="form-input" placeholder="Npr. Paws &amp; Claws Vet" />
            <span asp-validation-for="Name" class="form-validation"></span>
        </div>

        <!-- Row 2: Address -->
        <div class="form-group">
            <label class="form-label" asp-for="Address">Adresa</label>
            <input asp-for="Address" class="form-input" placeholder="Npr. Ilica 42, Zagreb" />
            <span asp-validation-for="Address" class="form-validation"></span>
        </div>

        <!-- Row 3: Phone + Email -->
        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="Phone">Telefon</label>
                <input asp-for="Phone" class="form-input" placeholder="Npr. 01 234 5678" />
                <span asp-validation-for="Phone" class="form-validation"></span>
            </div>
            <div class="form-group">
                <label class="form-label" asp-for="Email">Email</label>
                <input asp-for="Email" type="email" class="form-input"
                       placeholder="Npr. info@klinika.hr" />
                <span asp-validation-for="Email" class="form-validation"></span>
            </div>
        </div>

        <!-- Row 4: RegistrationNumber (half-width) -->
        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="RegistrationNumber">Registracijski broj</label>
                <input asp-for="RegistrationNumber" class="form-input"
                       placeholder="Npr. CLN-2024-001" />
                <span asp-validation-for="RegistrationNumber" class="form-validation"></span>
            </div>
            <div class="form-group"><!-- spacer --></div>
        </div>

        <!-- Row 5: MaxCapacity only (FoundationDate is immutable after creation) -->
        <div class="form-row">
            <div class="form-group">
                <label class="form-label" asp-for="MaxCapacity">Uredi Maksimalni Kapacitet</label>
                <input asp-for="MaxCapacity" type="number" class="form-input" placeholder="Npr. 50" />
                <span asp-validation-for="MaxCapacity" class="form-validation"></span>
            </div>
            <div class="form-group"><!-- spacer --></div>
        </div>

    <div class="form-footer">
        <a href="/clinics/@Model.Id" class="btn-secondary">Odustani</a>
        <button type="submit" class="btn-primary">&#128190; Spremi Izmjene</button>
    </div>
</form>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
