@model Owner
@{
    ViewData["Title"] = $"{Model.FirstName} {Model.LastName}";
}

<nav class="breadcrumbs">
    <a href="/">Nadzorna plo&#269;a</a>
    <span class="separator">/</span>
    <a href="/owners">Vlasnici</a>
    <span class="separator">/</span>
    <span class="current">@Model.FirstName @Model.LastName</span>
</nav>

<a href="/owners" class="btn-back">&#8592; Natrag na Vlasnike</a>

<div class="card-actions" style="margin-bottom:1rem;">
    <a href="/owners/@Model.Id/edit" class="btn-edit">&#9999; Uredi</a>
    <form asp-action="Delete" asp-controller="Owner" asp-route-id="@Model.Id"
          method="post"
          onsubmit="return confirm('Trajno ukloniti vlasnika @Model.FirstName @Model.LastName?')">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn-danger">&#128465; Ukloni</button>
    </form>
</div>

<div class="details-grid">
    <div class="glass-card details-hero">
        <div class="hero-avatar" style="width:100px;height:100px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:3rem;background:linear-gradient(135deg,rgba(0,230,118,0.35),rgba(0,230,118,0.1));margin-bottom:1.25rem;">👤</div>
        <div class="hero-name">@Model.FirstName @Model.LastName</div>
        <div class="hero-breed">ID: @Model.IdNumber</div>

        <div class="info-grid" style="width:100%;margin-top:1.5rem;">
            <div class="info-item">
                <div class="info-label">Email</div>
                <div class="info-value">@Model.Email</div>
            </div>
            <div class="info-item">
                <div class="info-label">Telefon</div>
                <div class="info-value">@Model.Phone</div>
            </div>
            <div class="info-item">
                <div class="info-label">Adresa</div>
                <div class="info-value">@Model.Address</div>
            </div>
            <div class="info-item">
                <div class="info-label">Registriran</div>
                <div class="info-value">@Model.RegistrationDate.ToString("d")</div>
            </div>
        </div>
    </div>

    <div>
        <div class="glass-card" style="margin-bottom:1.5rem;">
            <h3 class="section-title">🏥 Klinika</h3>
            @if (Model.Clinic != null)
            {
                <a href="/clinics/@Model.Clinic.Id" class="timeline-link">
                    <div class="timeline-item">
                        <div class="timeline-date" style="background:rgba(0,188,212,0.15);">
                            <span class="day" style="font-size:1.3rem;">&#127973;</span>
                        </div>
                        <div class="timeline-body" style="flex:1;">
                            <div class="tl-reason">@Model.Clinic.Name</div>
                            <div class="tl-vet">@Model.Clinic.Address</div>
                        </div>
                    </div>
                </a>
            }
            else
            {
                <div class="empty-state">Nema dodijeljene klinike.</div>
            }
        </div>

        <div class="glass-card">
            <h3 class="section-title">🐾 Ljubimci</h3>
            @if (Model.Patients.Any())
            {
                @foreach (var pet in Model.Patients)
                {
                    var emoji = pet.Species switch
                    {
                        AnimalSpecies.Dog => "🐕",
                        AnimalSpecies.Cat => "🐈",
                        AnimalSpecies.Bird => "🐦",
                        AnimalSpecies.Rabbit => "🐇",
                        AnimalSpecies.Hamster => "🐹",
                        _ => "🐾"
                    };
                    <a href="/patients/@pet.Id" class="timeline-link">
                        <div class="timeline-item">
                            <div class="timeline-date" style="background:rgba(108,99,255,0.15);font-size:1.5rem;">
                                <span>@emoji</span>
                            </div>
                            <div class="timeline-body" style="flex:1;">
                                <div class="tl-reason">@pet.Name</div>
                                <div class="tl-vet">@pet.Breed · @pet.Species.GetDisplayName() · @pet.Weight kg</div>
                            </div>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="empty-state">Nema registriranih ljubimaca.</div>
            }
        </div>
    </div>
</div>
