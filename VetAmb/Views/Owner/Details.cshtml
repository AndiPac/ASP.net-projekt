@model Owner
@{
    ViewData["Title"] = $"{Model.FirstName} {Model.LastName}";
}

<nav class="breadcrumbs">
    <a href="/">Dashboard</a>
    <span class="separator">/</span>
    <a href="/Owner">Owners</a>
    <span class="separator">/</span>
    <span class="current">@Model.FirstName @Model.LastName</span>
</nav>

<a href="/Owner" class="btn-back">← Back to Owners</a>

<div class="details-grid">
    <div class="glass-card details-hero">
        <div class="hero-avatar" style="width:100px;height:100px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:3rem;background:linear-gradient(135deg,rgba(0,230,118,0.35),rgba(0,230,118,0.1));margin-bottom:1.25rem;">👤</div>
        <div class="hero-name">@Model.FirstName @Model.LastName</div>
        <div class="hero-breed">ID: @Model.IdNumber</div>

        <div class="info-grid" style="width:100%;margin-top:1.5rem;">
            <div class="info-item">
                <div class="info-label">Email</div>
                <div class="info-value">@Model.Email</div>
            </div>
            <div class="info-item">
                <div class="info-label">Phone</div>
                <div class="info-value">@Model.Phone</div>
            </div>
            <div class="info-item">
                <div class="info-label">Address</div>
                <div class="info-value">@Model.Address</div>
            </div>
            <div class="info-item">
                <div class="info-label">Registered</div>
                <div class="info-value">@Model.RegistrationDate.ToString("MMMM dd, yyyy")</div>
            </div>
        </div>
    </div>

    <div>
        <div class="glass-card" style="margin-bottom:1.5rem;">
            <h3 class="section-title">🏥 Clinic</h3>
            <div class="info-grid">
                <div class="info-item">
                    <div class="info-label">Name</div>
                    <div class="info-value">@Model.Clinic?.Name</div>
                </div>
                <div class="info-item">
                    <div class="info-label">Address</div>
                    <div class="info-value">@Model.Clinic?.Address</div>
                </div>
            </div>
        </div>

        <div class="glass-card">
            <h3 class="section-title">🐾 Pets</h3>
            @if (Model.Patients.Any())
            {
                @foreach (var pet in Model.Patients)
                {
                    var emoji = pet.Species switch
                    {
                        AnimalSpecies.Dog => "🐕",
                        AnimalSpecies.Cat => "🐈",
                        AnimalSpecies.Bird => "🐦",
                        AnimalSpecies.Rabbit => "🐇",
                        AnimalSpecies.Hamster => "🐹",
                        _ => "🐾"
                    };
                    <div class="timeline-item">
                        <div class="timeline-date" style="background:rgba(108,99,255,0.15);font-size:1.5rem;">
                            <span>@emoji</span>
                        </div>
                        <div class="timeline-body" style="flex:1;">
                            <div class="tl-reason">@pet.Name</div>
                            <div class="tl-vet">@pet.Breed · @pet.Species · @pet.Weight kg</div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">No pets registered.</div>
            }
        </div>
    </div>
</div>
