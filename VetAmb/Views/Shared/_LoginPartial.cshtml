@using Microsoft.AspNetCore.Identity
@using VetAmb.Models
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

<div class="d-flex align-items-center gap-3 flex-nowrap m-0 p-0" style="display: flex !important; flex-direction: row !important;">
@if (SignInManager.IsSignedIn(User))
{
    <span class="text-dark fw-medium text-nowrap">@User.Identity?.Name</span>
    <form class="form-inline m-0 p-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/">
        <button type="submit" class="auth-glass-btn text-nowrap">Odjava</button>
    </form>
}
else
{
    <div class="d-flex align-items-center flex-nowrap gap-2">
        <a class="auth-glass-btn text-nowrap" asp-area="Identity" asp-page="/Account/Register">Registracija</a>
        <a class="auth-glass-btn text-nowrap" asp-area="Identity" asp-page="/Account/Login">Prijava</a>
    </div>
}
</div>