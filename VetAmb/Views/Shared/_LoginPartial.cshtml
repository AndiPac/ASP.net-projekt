@using Microsoft.AspNetCore.Identity
@using VetAmb.Models
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <div class="auth-login-partial auth-login-partial-signed-in">
        <span class="auth-username">@User.Identity?.Name</span>
        <form class="auth-logout-form" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="/">
            <button type="submit" class="auth-glass-btn">Odjava</button>
        </form>
    </div>
}
else
{
    <div class="auth-login-partial auth-login-partial-guest">
        <a class="auth-glass-btn" asp-area="Identity" asp-page="/Account/Register">Registracija</a>
        <a class="auth-glass-btn" asp-area="Identity" asp-page="/Account/Login">Prijava</a>
    </div>
}