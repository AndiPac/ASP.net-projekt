@{
    var statusCode = (int?)ViewData["StatusCode"] ?? 500;
    var title = (string?)ViewData["Title"] ?? "Dogodila se pogreška";

    var message = statusCode switch
    {
        404 => "Tražena stranica ne postoji ili je uklonjena.",
        403 => "Nemate dopuštenje za pristup ovoj stranici.",
        _ => "Došlo je do neočekivane pogreške. Pokušajte ponovno." 
    };
}

<section class="glass-panel" style="max-width: 760px; margin: 2rem auto; padding: 1.75rem;">
    <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
        <h1 style="margin:0;">@title</h1>
        <span class="status-badge">HTTP @statusCode</span>
    </div>

    <p style="margin-top: 1rem; color: var(--text-secondary);">@message</p>
</section>
