@* ============================================================
   _CustomDateTimePicker.cshtml — VetAmb Custom Date+Time Picker
   Usage:
     @await Html.PartialAsync("_CustomDateTimePicker", new ViewDataDictionary(ViewData)
     {
         ["FieldName"]  = "AppointmentDateTime",   // model binding name
         ["FieldId"]    = "appointmentDateTime",    // element id (no dots)
         ["LabelText"]  = "Appointment Date & Time",
         ["Value"]      = Model.AppointmentDateTime // nullable DateTime?
     })
   RULES:
     - No type="date" or type="datetime-local" — native picker is bypassed entirely.
     - All visual language follows the site-wide Modern Glassmorphism design system.
     - JS formats selected value as  dd.MM.yyyy HH:mm  (hr) or  MM/dd/yyyy hh:mm tt (en-US).
   ============================================================ *@

@using System.Globalization

@{
    var fieldName   = ViewData["FieldName"]  as string ?? "DateField";
    var fieldId     = ViewData["FieldId"]    as string ?? "dateField";
    var labelText   = ViewData["LabelText"]  as string ?? "Date & Time";
    var rawValue    = ViewData["Value"];
    // Optional client-side required validation.
    var isRequired   = ViewData["Required"] is bool rb && rb;
    var requiredMsg  = ViewData["RequiredMessage"] as string ?? "Ovo polje je obavezno.";
    // Read browser's actual locale from Accept-Language header — bypasses DefaultThreadCurrentCulture
    // being globally pinned to hr-HR, which would make CultureInfo.CurrentCulture always Croatian.
    var acceptLang  = Context.Request.Headers.AcceptLanguage.FirstOrDefault() ?? "";
    var primaryLang = acceptLang.Split(',', ';')[0].Trim();
    var isHr        = string.IsNullOrEmpty(primaryLang)
                      || primaryLang.StartsWith("hr", StringComparison.OrdinalIgnoreCase);
    var dateFormat  = isHr ? "dd.MM.yyyy HH:mm" : "MM/dd/yyyy hh:mm tt";
    var placeholder = isHr ? "dd.MM.yyyy HH:mm" : "MM/dd/yyyy hh:mm tt";
    var formattedValue = "";
    if (rawValue is DateTime dtVal && dtVal != default)
        // Use InvariantCulture + explicit pattern so output exactly matches both the
        // JS parseFormattedDate regexes and the controller's ParseDate TryParseExact patterns.
        formattedValue = dtVal.ToString(dateFormat, CultureInfo.InvariantCulture);
    else if (rawValue is string strVal && !string.IsNullOrEmpty(strVal))
        formattedValue = strVal; // Pre-formatted string passed from Edit view
}

<div class="cdp-wrapper" id="cdp-wrapper-@fieldId">
    <label class="cdp-label" for="@(fieldId)_display">@labelText</label>

    <!-- Hidden input that ASP.NET Core model binding reads -->
    <input type="hidden"
           id="@fieldId"
           name="@fieldName"
           class="force-validate"
           value="@formattedValue"
           @(isRequired ? $"data-val=\"true\" data-val-required=\"{requiredMsg}\"" : "") />

    <!-- Visible styled text input - no native picker -->
    <div class="cdp-input-group">
        <input type="text"
               id="@(fieldId)_display"
               class="cdp-input"
               placeholder="@placeholder"
               value="@formattedValue"
               autocomplete="off"
               readonly />
        <span class="cdp-toggle-btn" data-target="@fieldId" title="Pick date and time">
            &#128197;
        </span>
    </div>

    @Html.ValidationMessage(fieldName, null, new { @class = "text-danger cdp-validation" })

    <!-- Dropdown panel -->
    <div class="cdp-panel" id="cdp-panel-@fieldId" style="display:none;" aria-hidden="true">

        <!-- Calendar header -->
        <div class="cdp-cal-header">
            <button type="button" class="cdp-nav" data-dir="prev" data-target="@fieldId">&#8249;</button>
            <span class="cdp-month-year" id="cdp-title-@fieldId"></span>
            <button type="button" class="cdp-nav" data-dir="next" data-target="@fieldId">&#8250;</button>
        </div>

        <!-- Day-of-week headers -->
        <div class="cdp-dow-row">
            @if (isHr)
            {
                <span>Po</span><span>Ut</span><span>Sr</span>
                <span>&#268;e</span><span>Pe</span><span>Su</span><span>Ne</span>
            }
            else
            {
                <span>Mo</span><span>Tu</span><span>We</span>
                <span>Th</span><span>Fr</span><span>Sa</span><span>Su</span>
            }
        </div>

        <!-- Day cells injected by JS -->
        <div class="cdp-days" id="cdp-days-@fieldId"></div>

        <!-- Time row -->
        <div class="cdp-time-row">
            <span class="cdp-time-label">@(isHr ? "Sat" : "Time")</span>
            <div class="cdp-time-spinner">
                <button type="button" class="cdp-spin" data-unit="hour" data-dir="up"   data-target="@fieldId">&#9650;</button>
                <span   class="cdp-time-val"  id="cdp-hour-@fieldId">00</span>
                <button type="button" class="cdp-spin" data-unit="hour" data-dir="down" data-target="@fieldId">&#9660;</button>
            </div>
            <span class="cdp-colon">:</span>
            <div class="cdp-time-spinner">
                <button type="button" class="cdp-spin" data-unit="min" data-dir="up"   data-target="@fieldId">&#9650;</button>
                <span   class="cdp-time-val" id="cdp-min-@fieldId">00</span>
                <button type="button" class="cdp-spin" data-unit="min" data-dir="down" data-target="@fieldId">&#9660;</button>
            </div>
            <div class="cdp-ampm-wrap" id="cdp-ampm-wrap-@fieldId" style="display:none;">
                <button type="button" class="cdp-ampm-btn" id="cdp-ampm-@fieldId">AM</button>
            </div>
        </div>

        <!-- Confirm -->
        <div class="cdp-footer">
            <button type="button" class="cdp-confirm-btn" data-target="@fieldId">@(isHr ? "Potvrdi" : "Confirm")</button>
        </div>
    </div>
</div>

