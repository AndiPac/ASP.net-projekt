@page
@model VetAmb.Areas.Identity.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Zabranjen pristup";
}

<div class="auth-page">
    <div class="glass-card form-glass auth-form-card">
        <h1 class="section-title auth-title">Zabranjen pristup</h1>
        <p style="margin-bottom: 0.75rem; color: #111;">Nemate pravo pristupa traženoj stranici.</p>
        <p style="margin-bottom: 1.25rem; color: rgba(17, 17, 17, 0.72);">Ako mislite da biste trebali imati pristup, obratite se administratoru sustava.</p>

        <div class="card-actions" style="justify-content: flex-end; gap: 0.75rem;">
            <a class="btn-secondary" href="@Model.BackUrl">Natrag</a>
            <a class="btn-primary" href="/">Povratak na početnu</a>
        </div>
    </div>
</div>