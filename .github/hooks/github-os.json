{
    "hooks": {
        "UserPromptSubmit": [
            {
                "type": "command",
                "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File 'C:\\git\\.github\\hooks\\log-interaction.ps1'"
            }
        ],
        "PreToolUse": [
            {
                "type": "command",
                "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File 'C:\\git\\.github\\hooks\\log-interaction.ps1'"
            }
        ],
        "AgentResponse": [
            {
                "type": "command",
                "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"Add-Content -Path 'C:\\git\\.github\\hooks\\agent_log.txt' -Value 'LOG: UX Sub-Agent spawned using ux-agent-instructions.md'\""
            }
        ]
    }
}