      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -Command \"$input | & '.\\log-interaction.ps1'\""
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -Command \"$input | & '.\\log-interaction.ps1'\""
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -Command \"$input | & '.\\log-interaction.ps1'\""
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -Command \"$input | & '.\\log-interaction.ps1'\""
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -Command \"$input | & '.\\log-interaction.ps1'\""
      }
    ],
    "AgentResponse": [
      {
        "type": "command",
        "command": "powershell.exe -ExecutionPolicy Bypass -Command \"$input | & '.\\log-interaction.ps1'\""
      }
    ]
  }
