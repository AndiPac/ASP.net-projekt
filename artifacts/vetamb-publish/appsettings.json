{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=VetAmbDb;Trusted_Connection=true;MultipleActiveResultSets=true;TrustServerCertificate=true;"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.File", "Serilog.Sinks.Console" ],
    "Properties": {
      "Application": "VetAmb"
    },
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "fileSizeLimitBytes": 10485760,
          "retainedFileCountLimit": 14,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] ({RequestId}) {SourceContext} {Message:lj} | user={UserId} route={Route}{NewLine}{Exception}"
        }
      }
    ]
  },
  "OpenAI": {
    "ApiKey": "PLACEHOLDER_SET_IN_USER_SECRETS_OR_ENV",
    "Model": "gpt-4o-mini"
  },
  "Mcp": {
    "Enabled": true,
    "AllowInProduction": false,
    "ReadOnlyByDefault": true,
    "AllowWriteOperations": false,
    "RequireAuthenticatedUserForWrite": false,
    "WriteRoles": [ "Admin" ]
  },
  "AllowedHosts": "*"
}
